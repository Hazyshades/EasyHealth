# Skip validation during build (set to 1 in CI)
# SKIP_ENV_VALIDATION=1

# App URL
URL=http://localhost:3000

# Supabase - https://supabase.com/dashboard/project/_/settings/api
# Auth: enable Google + Email magic link; redirect = {URL}/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI extraction & summaries (OpenAI = ChatGPT default)
OPENAI_API_KEY=your-openai-api-key

# Optional: enable DeepSeek as a user-selectable provider in AI Settings
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Optional: Tencent Hy3 (free) via OpenRouter (https://openrouter.ai/tencent/hy3:free)
OWL_ALPHA_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OWL_ALPHA_MODEL=tencent/hy3:free

# Optional Nebius
# NEBIUS_API_KEY=
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1

# Optional Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Document worker (optional — required for async upload processing)
# WORKER_POLL_INTERVAL_MS=5000
# NEXT_PUBLIC_TERMS_URL=
# NEXT_PUBLIC_PRIVACY_URL=
# NEXT_PUBLIC_COOKIE_POLICY_URL=
